# --- Football data (shared World Cup feed). Free key: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# --- Vercel KV (auto-added to the project when you create a KV store in the Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Cloudflare Turnstile (bot check on creation). https://dash.cloudflare.com -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# --- Resend (emails the admin link). https://resend.com  (optional: link is shown on screen anyway)
RESEND_API_KEY=
EMAIL_FROM="Sweepstake <onboarding@resend.dev>"

# --- Your private usage dashboard token at /admin?t=...  (make up a long random string)
OWNER_TOKEN=

# --- Public base URL (used in emailed links). Optional; inferred from the request if unset.
APP_URL=
